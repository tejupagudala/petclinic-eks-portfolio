#!/bin/bash
set -euo pipefail

REGION="${region}"
ORG="${github_org}"
REPO="${github_repo}"
PARAM_NAME="${github_runner_pat_parameter_name}"
RUNNER_DIR="/opt/actions-runner"
RUNNER_USER="ec2-user"

if [ -f "$RUNNER_DIR/.runner" ]; then
  exit 0
fi

dnf -y install jq tar gzip

mkdir -p "$RUNNER_DIR"
chown -R "$RUNNER_USER:$RUNNER_USER" "$RUNNER_DIR"

cd "$RUNNER_DIR"
LATEST="$(curl -s https://api.github.com/repos/actions/runner/releases/latest | jq -r .tag_name)"
VERSION="$${LATEST#v}"
if [ ! -f "actions-runner-linux-x64-$VERSION.tar.gz" ]; then
  curl -s -L -o "actions-runner-linux-x64-$VERSION.tar.gz" \
    "https://github.com/actions/runner/releases/download/v$VERSION/actions-runner-linux-x64-$VERSION.tar.gz"
fi
tar xzf "actions-runner-linux-x64-$VERSION.tar.gz"
chown -R "$RUNNER_USER:$RUNNER_USER" "$RUNNER_DIR"

# Required .NET dependencies for runner on AL2023
dnf -y install libicu openssl-libs krb5-libs zlib libstdc++ libgcc lttng-ust libunwind libuuid || \
  dnf -y install icu openssl-libs krb5-libs zlib libstdc++ libgcc lttng-ust libunwind libuuid

PAT="$(aws ssm get-parameter --name "$PARAM_NAME" --with-decryption --region "$REGION" --query Parameter.Value --output text)"
if [ -z "$PAT" ] || [ "$PAT" = "None" ]; then
  echo "Missing GitHub PAT in SSM parameter: $PARAM_NAME"
  exit 1
fi

REG_TOKEN="$(curl -s -X POST \
  -H "Authorization: token $PAT" \
  -H "Accept: application/vnd.github+json" \
  "https://api.github.com/repos/$ORG/$REPO/actions/runners/registration-token" | jq -r .token)"

if [ -z "$REG_TOKEN" ] || [ "$REG_TOKEN" = "null" ]; then
  echo "Failed to obtain GitHub runner registration token."
  exit 1
fi

RUNNER_NAME="${cluster_name}-runner-$(hostname)"
su - "$RUNNER_USER" -c "$RUNNER_DIR/config.sh --url https://github.com/$ORG/$REPO --token $REG_TOKEN --unattended --name $RUNNER_NAME --labels self-hosted,linux,aws-vpc --replace"

cd "$RUNNER_DIR"
./svc.sh install
./svc.sh start
