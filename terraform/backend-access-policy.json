{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "StateBucketList",
      "Effect": "Allow",
      "Action": ["s3:ListBucket"],
      "Resource": "arn:aws:s3:::terraform-demo-eks-state-lock-bucket"
    },
    {
      "Sid": "StateAndLockRW",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject", "s3:DeleteObject"],
      "Resource": "arn:aws:s3:::terraform-demo-eks-state-lock-bucket/terraform.lock.tfstate*"
    }
  ]
}
